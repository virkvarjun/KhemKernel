# Virtual environment
.venv/

# Data (keep .gitkeep, ignore everything else)
data/*
!data/.gitkeep

# Editable install metadata
*.egg-info/

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.py[cod]

# Test cache
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# Model weights and large data files
*.npz
*.parquet
*.json

# Site (Astro) — allow its config/manifest files
!picochem-site/**/*.json

# Interactive guide (Vite app) — allow its config + precomputed data json
!demo/web/**/*.json

# macOS
.DS_Store

# IDEs
.vscode/
.idea/

# Claude Code local/personal config (not shared)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Experiment results
results/*
!results/.gitkeep

# Logging
wandb/
runs/
tensorboard_logs/

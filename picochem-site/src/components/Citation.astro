---
interface Props {
  title?: string;
  author?: string;
  year?: string | number;
  url?: string;
}
const { title, author, year, url } = Astro.props;
const slug = (Astro.url.pathname || '').replace(/\W+/g, '-').replace(/^-|-$/g, '') || 'post';
const bibKey = `${(author || 'virk').toLowerCase().split(/\s+/)[0]}${year || new Date().getFullYear()}${slug.split('-').slice(-1)[0] || ''}`;
const bibtex = `@misc{${bibKey},
  author       = {${author || 'Virk, Arjun'}},
  title        = {${title || 'Untitled'}},
  year         = {${year || new Date().getFullYear()}},
  howpublished = {\\url{${url || Astro.url.toString()}}},
  note         = {Accessed: ${new Date().toISOString().slice(0, 10)}}
}`;
---

<p class="cite-line text-muted text-small">If you reference this post, please cite it as:</p>
<div class="citation-block" data-bibtex={bibtex}>
  <button type="button" class="copy-btn" aria-label="Copy BibTeX">Copy</button>
  <code>{bibtex}</code>
</div>

<script is:inline>
  document.querySelectorAll('.citation-block .copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const block = btn.closest('.citation-block');
      const text = block?.getAttribute('data-bibtex') || '';
      try {
        await navigator.clipboard.writeText(text);
        const orig = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(() => (btn.textContent = orig), 1400);
      } catch (e) {}
    });
  });
</script>

<style>
  .cite-line { margin: 1rem 0 0.5rem; }
  .citation-block code {
    background: transparent;
    padding: 0;
    font-size: inherit;
    color: var(--fg);
  }
</style>

---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  wide?: boolean;
}
const { src, alt, caption, wide = false } = Astro.props;
---

<figure class={wide ? 'figure full-bleed' : 'figure'}>
  <img src={src} alt={alt} loading="lazy" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

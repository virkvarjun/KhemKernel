---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  wide?: boolean;
}
const { src, alt, caption, wide = false } = Astro.props;
// Resolve site-absolute paths against the configured base (e.g. /KhemKernel)
// so images work on a project page; leaves external and relative URLs alone.
const resolved = src.startsWith('/')
  ? import.meta.env.BASE_URL.replace(/\/$/, '') + src
  : src;
---

<figure class={wide ? 'figure figure-wide' : 'figure'}>
  <img src={resolved} alt={alt} loading="lazy" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .figure-wide {
    margin-left: calc(-1 * var(--media-breakout, 60px));
    margin-right: calc(-1 * var(--media-breakout, 60px));
  }
  @media (max-width: 900px) {
    .figure-wide { margin-left: 0; margin-right: 0; }
  }
</style>

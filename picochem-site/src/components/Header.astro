---
const base = import.meta.env.BASE_URL;
const { pathname } = Astro.url;
const strip = (s: string) => (s.endsWith('/') && s.length > 1 ? s.slice(0, -1) : s);
const isActive = (href: string) =>
  strip(href) === strip(base) ? strip(pathname) === strip(base) : pathname.startsWith(strip(href));
---

<header id="header" class="site-header">
  <div class="site-header-inner">
    <div class="navbar-logo">
      <a href={base} aria-label="picochem home">PICOCHEM</a>
    </div>
    <nav class="top-nav" aria-label="Primary">
      <a href={base} class={isActive(base) ? 'is-active' : ''}>Blog</a>
      <a href={`${base}about`} class={isActive(`${base}about`) ? 'is-active' : ''}>About</a>
      <button
        type="button"
        id="theme-toggle"
        aria-label="Toggle dark mode"
        title="Toggle theme"
      >
        <svg id="sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <svg id="moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
        </svg>
      </button>
    </nav>
  </div>
</header>

<style>
  .site-header {
    height: var(--site-header-height);
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    backdrop-filter: saturate(140%) blur(6px);
    -webkit-backdrop-filter: saturate(140%) blur(6px);
    border-bottom: 1px solid var(--rule);
  }
  .site-header-inner {
    max-width: var(--measure-wide);
    height: 100%;
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .navbar-logo a {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.18em;
    color: var(--fg2);
    text-decoration: none;
  }
  .navbar-logo a:hover { color: var(--fg); opacity: 0.85; }

  .top-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .top-nav a {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--fg3);
    text-decoration: none;
    letter-spacing: 0.005em;
    padding: 0.25rem 0;
  }
  .top-nav a:hover { color: var(--fg); }
  .top-nav a.is-active { color: var(--fg); }

  #theme-toggle {
    background: transparent;
    border: 0;
    color: var(--fg3);
    cursor: pointer;
    padding: 0.25rem 0.3rem;
    display: inline-flex;
    align-items: center;
    border-radius: 3px;
    margin-left: 0.25rem;
  }
  #theme-toggle:hover { color: var(--fg); }
  :global([data-theme='dark']) #sun { display: none; }
  :global(:not([data-theme='dark'])) #moon { display: none; }
</style>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) {}
    });
  })();
</script>

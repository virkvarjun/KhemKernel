---
export interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props { headings: Heading[] }
const { headings } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{items.length > 0 && (
  <aside class="toc" aria-label="Table of contents">
    <p class="toc-label">Contents</p>
    <ol>
      {items.map((h) => (
        <li class={`toc-item depth-${h.depth}`}>
          <a href={`#${h.slug}`} data-slug={h.slug}>{h.text}</a>
        </li>
      ))}
    </ol>
  </aside>
)}

<style>
  .toc {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    line-height: 1.5;
  }
  .toc-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-subtle);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }
  .toc ol {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--rule);
  }
  .toc li {
    margin: 0;
    padding: 0;
  }
  .toc a {
    display: block;
    padding: 0.3rem 0 0.3rem 0.85rem;
    color: var(--text-muted);
    border-bottom: 0;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 120ms, border-color 120ms;
  }
  .toc a:hover { color: var(--text); }
  .toc .depth-3 a { padding-left: 1.75rem; font-size: 0.78rem; }
  .toc a.is-active {
    color: var(--accent);
    border-left-color: var(--accent);
  }
</style>

<script is:inline>
  (function () {
    if (typeof IntersectionObserver === 'undefined') return;
    const links = document.querySelectorAll('.toc a[data-slug]');
    if (!links.length) return;
    const map = new Map();
    links.forEach((a) => map.set(a.getAttribute('data-slug'), a));
    const headings = Array.from(map.keys())
      .map((slug) => document.getElementById(slug))
      .filter(Boolean);
    if (!headings.length) return;

    let activeSlug = null;
    const setActive = (slug) => {
      if (slug === activeSlug) return;
      activeSlug = slug;
      links.forEach((l) => l.classList.toggle('is-active', l.getAttribute('data-slug') === slug));
    };

    const obs = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible.length) {
          setActive(visible[0].target.id);
        }
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 },
    );
    headings.forEach((h) => obs.observe(h));
  })();
</script>

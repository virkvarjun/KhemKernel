---
// TM-style sidenote: number + tooltip-on-narrow / margin note on wide.
// Usage: <Footnote>content</Footnote>
// (numbering is automatic via CSS counter on .prose)
interface Props { n?: string | number }
const { n } = Astro.props;
---

<span class="sidenote-number" tabindex="0" data-n={n ?? ''}>
  <span class="sidenote"><slot /></span>
</span>

<style>
  .sidenote-number { /* counter, color, tooltip behavior all in global.css */ }
</style>

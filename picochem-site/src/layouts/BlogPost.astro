---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import PostMeta from '../components/PostMeta.astro';
import Citation from '../components/Citation.astro';
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  heroImage?: string;
  headings: MarkdownHeading[];
  readingTime?: number;
}

const { title, description, pubDate, updatedDate, author, heroImage, headings, readingTime } =
  Astro.props;
---

<BaseLayout title={title} description={description} type="article" pubDate={pubDate} ogImage={heroImage}>
  <article class="post">
    <header class="post-header container">
      <h1 class="post-title">{title}</h1>
      <PostMeta author={author} pubDate={pubDate} updatedDate={updatedDate} readingTime={readingTime} />
      {description && <p class="post-dek text-muted">{description}</p>}
    </header>

    {heroImage && (
      <div class="post-hero container-wide">
        <img src={heroImage} alt="" loading="eager" />
      </div>
    )}

    <div class="post-body">
      <aside class="post-toc">
        <div class="post-toc-inner">
          <TableOfContents headings={headings} />
        </div>
      </aside>

      <div class="prose post-prose">
        <slot />

        <hr />
        <Citation title={title} author={author} year={pubDate.getFullYear()} />

        <p class="post-bottom-nav">
          <a href="#top" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">↑ Back to top</a>
          <span aria-hidden="true">·</span>
          <a href="/">All posts</a>
        </p>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post { padding: 2.5rem 0 1rem; }
  .post-header { text-align: center; margin-bottom: 2rem; }
  .post-title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin-bottom: 0.75rem;
    text-wrap: balance;
  }
  .post-dek {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    max-width: 620px;
    margin: 0 auto;
    color: var(--text-muted);
    text-wrap: pretty;
  }
  .post-hero {
    margin: 2rem auto 3rem;
  }
  .post-hero img {
    width: 100%;
    border-radius: 4px;
    border: 1px solid var(--rule);
  }

  .post-body {
    position: relative;
    max-width: var(--measure-wide);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  .post-prose { padding-top: 1rem; }

  .post-toc { display: none; }

  /* Desktop layout: TOC on the left, prose centered */
  @media (min-width: 1100px) {
    .post-body {
      max-width: none;
      padding: 0;
    }
    .post-toc {
      display: block;
      position: sticky;
      top: 5rem;
      align-self: flex-start;
      width: 220px;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
      float: left;
      margin-left: max(1.5rem, calc((100vw - var(--measure)) / 2 - 260px));
    }
    .post-toc-inner { padding: 0.25rem 0 1rem; }
    .post-prose {
      max-width: var(--measure);
      margin: 0 auto;
      padding-top: 1rem;
    }
  }

  /* Mobile: collapsible top TOC */
  @media (max-width: 1099px) {
    .post-toc {
      display: block;
      max-width: var(--measure);
      margin: 0 auto 2rem;
    }
  }

  .post-bottom-nav {
    margin-top: 2.5rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .post-bottom-nav span[aria-hidden] { color: var(--text-subtle); }
  .post-bottom-nav a { border-bottom: 0; }
  .post-bottom-nav a:hover { color: var(--accent); }
</style>

---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Citation from '../components/Citation.astro';
import type { MarkdownHeading } from 'astro';
import { getCollection } from 'astro:content';

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  heroImage?: string;
  headings: MarkdownHeading[];
  readingTime?: number;
}

const { slug, title, description, pubDate, updatedDate, author, heroImage, headings, readingTime } =
  Astro.props;

const all = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const idx = all.findIndex((p) => p.id === slug);
const newer = idx > 0 ? all[idx - 1] : null;
const older = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  pubDate={pubDate}
  ogImage={heroImage}
>
  <main id="main" class="post">
    <header class="post-heading">
      <p class="eyebrow">Picochem · Notebook</p>
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-subtitle">{description}</p>}
      <div class="publish-metadata">
        <span class="author">{author}</span>
        <span class="meta-row">
          <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
          {updatedDate && (
            <>
              <span class="dot" aria-hidden="true">·</span>
              <span>Updated {fmt(updatedDate)}</span>
            </>
          )}
          {readingTime && (
            <>
              <span class="dot" aria-hidden="true">·</span>
              <span>{readingTime} min read</span>
            </>
          )}
        </span>
      </div>
    </header>

    {heroImage && (
      <div class="post-cover">
        <img src={heroImage} alt="" loading="eager" />
      </div>
    )}

    <div class="post-grid">
      <TableOfContents headings={headings} />
      <article class="content prose">
        <slot />

        <section class="post-end">
          <h2 id="citation">Citation</h2>
          <Citation title={title} author={author} year={pubDate.getFullYear()} />
        </section>

        <nav class="post-nav" aria-label="Adjacent posts">
          {older ? (
            <a class="post-nav-prev" href={`/blog/${older.id}/`}>
              <span class="eyebrow">← Older</span>
              <span class="post-nav-title">{older.data.title}</span>
            </a>
          ) : <span />}
          {newer ? (
            <a class="post-nav-next" href={`/blog/${newer.id}/`}>
              <span class="eyebrow">Newer →</span>
              <span class="post-nav-title">{newer.data.title}</span>
            </a>
          ) : <span />}
        </nav>

        <p class="back-to-top">
          <a href="#main">↑ Back to top</a>
        </p>
      </article>
    </div>
  </main>
</BaseLayout>

<style>
  #main.post {
    max-width: var(--measure-shell);
    margin: 0 auto;
    padding: 2.5rem var(--gutter) 0;
    position: relative;
  }
  @media (min-width: 1200px) {
    #main.post { max-width: 970px; --sidenote-width: 240px; }
  }
  @media (min-width: 1400px) {
    #main.post { max-width: 990px; --sidenote-width: 250px; }
  }
  @media (min-width: 1600px) {
    #main.post { max-width: 1010px; --sidenote-width: 275px; }
  }

  .post-heading {
    text-align: center;
    max-width: 570px;
    margin: 0 auto 0.5rem;
  }
  .post-heading .eyebrow { display: block; margin-bottom: 1rem; }
  .post-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 30px;
    line-height: 1.3;
    letter-spacing: -0.005em;
    margin: 0.25rem 0 0;
    color: var(--fg);
    text-wrap: balance;
  }
  .post-subtitle {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 18px;
    line-height: 1.5;
    color: var(--fg4);
    margin-top: 0.6rem;
    margin-bottom: 0;
    font-style: italic;
    text-wrap: pretty;
  }

  .publish-metadata {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-sans);
    color: var(--fg3);
    font-size: 14px;
    margin-top: 1.25rem;
    margin-bottom: 2rem;
  }
  .publish-metadata .author {
    color: var(--fg1);
    font-weight: 500;
    letter-spacing: 0.005em;
  }
  .publish-metadata .meta-row {
    color: var(--fg4);
    font-size: 13px;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .publish-metadata .dot { color: var(--fg5); }

  .post-cover {
    max-width: 860px;
    margin: 0 auto 3rem;
  }
  .post-cover img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--rule);
  }

  /* Article + TOC grid (desktop) */
  .post-grid {
    display: block;
    position: relative;
  }
  .content.prose {
    max-width: var(--measure-prose);
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .post-grid {
      display: grid;
      grid-template-columns: var(--toc-width) 1fr;
      column-gap: var(--toc-gap);
      align-items: start;
    }
    .post-grid :global(.left-toc) {
      position: sticky;
      top: calc(var(--site-header-height) + 1.5rem);
      max-height: calc(100vh - var(--site-header-height) - 3rem);
      overflow-y: auto;
      grid-column: 1;
    }
    .content.prose {
      grid-column: 2;
      margin: 0;
    }
  }
  @media (min-width: 1200px) {
    .post-grid {
      grid-template-columns: var(--toc-width) minmax(0, var(--measure-prose));
    }
  }

  /* Bottom navigation */
  .post-end { margin-top: 3rem; }
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 3rem 0 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }
  .post-nav a {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
    padding: 0.5rem 0;
    color: var(--fg);
  }
  .post-nav a:hover .post-nav-title { color: var(--accent); }
  .post-nav-next { text-align: right; }
  .post-nav-title {
    font-family: var(--font-serif);
    font-size: 15.5px;
    line-height: 1.4;
    transition: color 200ms;
  }
  .back-to-top {
    margin-top: 0.5rem;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--fg4);
  }
  .back-to-top a {
    text-decoration: none;
    color: var(--fg4);
  }
  .back-to-top a:hover { color: var(--accent); }
</style>
